# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=zal

# Redis
REDIS_URL=redis://redis:6379/0

# API
DATABASE_URL=postgresql://postgres:postgres@db:5432/zal?sslmode=disable
PORT=8080
ENV=development

# Демо аутентификация: простой токен на одного пользователя
# Каждый запрос с этим токеном в X-Demo-Token header будет аутентифицирован как демонстрационный пользователь
# Генерируется с: openssl rand -hex 16
DEMO_USER_TOKEN=changeme_user_token

# Admin: защищённые запросы до /admin/slots с статическим токеном, который передается в X-Admin-Token header
ADMIN_TOKEN=secret

# Web
VITE_API_URL=http://localhost:8080
