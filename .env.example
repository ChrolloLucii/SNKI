# ──────────────────────────────────────────────
# Zal MVP — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=zal

# API
DATABASE_URL=postgresql://postgres:postgres@db:5432/zal?sslmode=disable
PORT=8080
ENV=development

# Demo auth: simple token per user (no passwords in MVP)
# Each request passes X-User-Token header; the API maps it to a user row.
# Generate with: openssl rand -hex 16
DEMO_USER_TOKEN=changeme_user_token

# Admin: protect POST /admin/slots with a static token
ADMIN_TOKEN=secret

# Web (Vite)
VITE_API_URL=http://localhost:8080
